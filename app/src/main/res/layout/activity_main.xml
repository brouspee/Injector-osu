<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="osu! Injector"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Timing Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timing Windows"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Easy Timing"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editGreat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Great (ms)"
                android:inputType="number"/>

            <EditText
                android:id="@+id/editOK"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="OK (ms)"
                android:inputType="number"/>

            <EditText
                android:id="@+id/editMeh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Meh (ms)"
                android:inputType="number"/>
        </LinearLayout>

        <!--Radius Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hitbox Size"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable 3x Hitbox"/>

        <EditText
            android:id="@+id/editRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Radius multiplier (default 3)"
            android:inputType="number"/>

        <!-- Difficulty Modifiers -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Difficulty Override"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AR Override"/>

                <EditText
                    android:id="@+id/editAR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="AR (0-10)"
                    android:inputType="number"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCS"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CS Override"/>

                <EditText
                    android:id="@+id/editCS"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="CS (0-10)"
                    android:inputType="number"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchOD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OD Override"/>

                <EditText
                    android:id="@+id/editOD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="OD (0-10)"
                    android:inputType="number"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:layout_marginTop="24dp"/>

        <Button
            android:id="@+id/btnInject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inject DLL"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnPatchDLL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Build New DLL"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5722"
            android:layout_marginTop="16dp"/>
    </LinearLayout>
</ScrollView>
