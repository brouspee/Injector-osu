<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="8dp">

    <!-- Header with toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/overlay_btnToggle"
            android:text="≡"
            android:layout_width="40dp"
            android:layout_height="40dp"/>

        <TextView
            android:text="osu! Injector"
            android:textColor="#00FF00"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:paddingLeft="8dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/overlay_btnClose"
            android:text="✕"
            android:layout_width="40dp"
            android:layout_height="40dp"/>
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/overlay_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Timing -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <TextView
                android:text="Timing:"
                android:textColor="#FFFFFF"
                android:layout_width="60dp"/>

            <Switch
                android:id="@+id/overlay_switchTiming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Hitbox -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <TextView
                android:text="Hitbox:"
                android:textColor="#FFFFFF"
                android:layout_width="60dp"/>

            <Switch
                android:id="@+id/overlay_switchRadius"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Save -->
        <Button
            android:id="@+id/overlay_btnSave"
            android:text="Save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</LinearLayout>
